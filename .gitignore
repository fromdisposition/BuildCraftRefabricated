# Whitelist: only src/, gradle/, and root project files are tracked.
/*

!/src/
!/src/**
!/gradle/
!/gradle/**
# Build inputs for generateFluidBucketAssets (not shipped in the mod JAR).
!/gradle/fluid_assets/
!/gradle/fluid_assets/**

!/.gitignore
!/.gitattributes
!/build.gradle.kts
!/settings.gradle.kts
!/stonecutter.gradle.kts
!/gradle.properties
!/gradlew
!/gradlew.bat
!/LICENSE
!/README.md
!/versions/1.21.1/gradle.properties
!/versions/1.21.11/gradle.properties
!/versions/26.1/gradle.properties
!/versions/26.2/gradle.properties

# Local / generated (also covered by whitelist above)
.gradle/
build/
run/
run_server/

# Fluid bake outputs under src/ ARE tracked (baked/, underwater/, heat_* templates,
# bucket_fluid icons). Regenerate via: ./gradlew generateFluidBucketAssets

# IDE / OS
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# Decompiler junk at repo root
/com/
/net/
