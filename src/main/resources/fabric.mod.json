{
  "schemaVersion": 1,
  "id": "buildcraftrefabricated",
  "version": "${mod_version}",
  "name": "BuildCraft Refabricated",
  "description": "Unofficial Fabric port of BuildCraft  — pipes, engines, quarries, oil processing, gates, and automation.",
  "authors": [
    "fromdisposition"
  ],
  "contributors": [
    "SpaceToad",
    "BuildCraft Team",
    "legoj15"
  ],
  "contact": {
    "homepage": "https://github.com/fromdisposition/BuildCraftRefabricated",
    "issues": "https://github.com/fromdisposition/BuildCraftRefabricated/issues",
    "sources": "https://github.com/fromdisposition/BuildCraftRefabricated"
  },
  "license": "MPL-2.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      "buildcraft.fabric.BuildCraftFabricMod"
    ],
    "client": [
      "buildcraft.fabric.BuildCraftFabricClient"
    ],
    "jei_mod_plugin": [
      "buildcraft.core.integration.jei.BCCoreJeiPlugin",
      "buildcraft.energy.integration.jei.BCEnergyJeiPlugin",
      "buildcraft.factory.integration.jei.BCFactoryJeiPlugin",
      "buildcraft.silicon.integration.jei.BCSiliconJeiPlugin"
    ],
    "fabric-datagen": [
      "buildcraft.energy.worldgen.datagen.BuildCraftWorldgenDataGenerator"
    ]
  },
  "mixins": [
    "buildcraft.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "${mc_dep_range}",
    "java": ">=25",
    "fabric-api": ">=${fabric_api_version}"
  },
  "suggests": {
    "jei": "*",
    "team_reborn_energy": ">=5.0.0"
  }
}